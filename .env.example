# ============================================
# NoteHaven - Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from your Supabase dashboard:
# Project Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key

# Project Settings > General > Reference ID
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ============================================
# External APIs (Optional)
# ============================================
# These are only needed for fetching NEW cover images
# Already have 653+ media items cached in Supabase!

# TMDB API Key - for movies and series covers
# Get free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# OMDB API Key - alternative movie source
# Get free API key at: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your-omdb-api-key

# ============================================
# Supabase Service Role Key (For Edge Functions)
# ============================================
# ⚠️ WARNING: Keep this secret! Never expose in frontend!
# Get from: Supabase Dashboard > Project Settings > API > service_role key
# This key bypasses Row Level Security - use only in edge functions!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# OLD VARIABLES (No longer needed - removed)
# ============================================
# The following are NOT needed anymore:
# - VITE_API_URL (no backend API)
# - MONGODB_URI (migrated to Supabase)
# - PORT (no backend server)
# - ALLOWED_ORIGINS (handled by edge function)
# - RATE_LIMIT_WINDOW_MS (handled by Supabase)
# - RATE_LIMIT_MAX_REQUESTS (handled by Supabase)