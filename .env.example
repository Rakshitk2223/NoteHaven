# Supabase Configuration (Public - safe to use in frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase Service Role Key (ADMIN - keep secret!)
# Required for backfill scripts and edge function deployments
# Get it from: Supabase Dashboard > Project Settings > API > service_role key
# WARNING: This key bypasses Row Level Security (RLS) - never expose it in frontend code!
SUPABASE_SERVICE_ROLE_KEY=

# External APIs
TMDB_API_KEY=
OMDB_API_KEY=
