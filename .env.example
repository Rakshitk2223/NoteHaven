# ============================================
# NoteHaven - Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from your Supabase dashboard:
# Project Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key

# Project Settings > General > Reference ID
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ============================================
# Backend API Configuration (Required for media covers)
# ============================================
# URL of the Express API server that fetches media cover images
# Default: http://localhost:3001 (for local development)
# Production: Your deployed API URL
VITE_API_URL=http://localhost:3001
