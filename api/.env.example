# ============================================
# NoteHaven API - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# MongoDB Configuration (Required)
# ============================================
# Get this from MongoDB Atlas:
# Database > Connect > Drivers > Node.js > Connection string
# Replace <password> with your database user password
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/notehaven?retryWrites=true&w=majority

# ============================================
# External Media APIs (Optional)
# ============================================
# These are used as fallback sources for media metadata
# If not provided, the API will only use AniList and Jikan (which don't require keys)

# TMDB (The Movie Database) API Key
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb (Open Movie Database) API Key
# Get from: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ============================================
# Server Configuration
# ============================================
# Port for the Express server to listen on
PORT=3001

# Environment mode (development/production)
NODE_ENV=development

# CORS - Allowed origins (comma-separated)
# Include your frontend URL(s) here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Rate Limiting Configuration (Optional)
# ============================================
# Time window for rate limiting in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window (default: 1000)
RATE_LIMIT_MAX_REQUESTS=1000
